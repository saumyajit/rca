{
	"_comment": "Hostname format: {env:2}{customer:4}{product:2}{type:2}{instance:3} = 13 chars fixed. Edit this file to add new codes — no PHP changes needed.",

	"format": {
		"total_length": 13,
		"segments": {
			"env":      { "offset": 0, "length": 2 },
			"customer": { "offset": 2, "length": 4 },
			"product":  { "offset": 6, "length": 2 },
			"type":     { "offset": 8, "length": 2 },
			"instance": { "offset": 10, "length": 3 }
		}
	},

	"environments": {
		"pr": { "name": "Production",  "short": "PROD", "color": "critical" },
		"ts": { "name": "Test",        "short": "TEST", "color": "warning"  },
		"dv": { "name": "Development", "short": "DEV",  "color": "ok"       }
	},

	"customers": {
		"bd19": { "name": "Google Inc",  "short": "Google",  "code": "bd19" },
		"lk02": { "name": "Amazon Inc",  "short": "Amazon",  "code": "lk02" }
	},

	"products": {
		"_comment": "Product codes are GLOBAL — same code means same product across all customers.",
		"01": { "name": "Android",     "short": "Android" },
		"02": { "name": "Grocery",     "short": "Grocery" },
		"03": { "name": "Web Portal",  "short": "WebPortal" },
		"04": { "name": "Analytics",   "short": "Analytics" },
		"05": { "name": "Payments",    "short": "Payments" },
		"06": { "name": "CRM",         "short": "CRM" },
		"07": { "name": "TBD",         "short": "TBD" },
		"08": { "name": "TBD",         "short": "TBD" },
		"09": { "name": "TBD",         "short": "TBD" }
	},

	"server_types": {
		"01": { "name": "Web Server",      "short": "Web",     "icon": "🌐", "layer": 4 },
		"02": { "name": "App Server",      "short": "App",     "icon": "⚡", "layer": 3 },
		"03": { "name": "SQL DB / MSSQL",  "short": "SQL DB",  "icon": "🗄", "layer": 2 },
		"04": { "name": "Oracle DB",       "short": "OraDB",   "icon": "🗄", "layer": 2 },
		"05": { "name": "Load Balancer",   "short": "LB",      "icon": "⚖", "layer": 5 },
		"06": { "name": "Citrix Server",   "short": "Citrix",  "icon": "🖥", "layer": 3 },
		"07": { "name": "Storage",         "short": "Storage", "icon": "💾", "layer": 1 }
	},

	"dependency_order": {
		"_comment": "Layer numbers define expected cascade direction. Lower layer = closer to infrastructure (more likely root cause). Higher = closer to user.",
		"1": "Storage",
		"2": "Database",
		"3": "Application / Citrix",
		"4": "Web",
		"5": "Load Balancer"
	},

	"hostgroup_patterns": {
		"_comment": "Regex patterns to extract metadata from Zabbix hostgroup names when hostname parse fails or is partial.",
		"customer": "^CUSTOMER\\/(.+)$",
		"product":  "^PRODUCT\\/(.+)$",
		"type":     "^TYPE\\/(.+)$"
	}
}
